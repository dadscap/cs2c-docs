---
import ApiReference from "../../layouts/ApiReference.astro";
import { render } from "astro:content";
import { getEntry } from "astro:content";

const entry = await getEntry("docs", "api/sub-keys");
const { Content } = await render(entry);
---

<ApiReference title="Sub-Keys — API Reference" description={entry.data.description} currentSection="sub-keys">
  <h1>{entry.data.title}</h1>
  <p class="text-muted">{entry.data.description}</p>
  <Content />
</ApiReference>
